    "shell_commands": [
        "show version",
        "cat /sys/block/mmcblk0/device/name",
        "/sbin/mmc extcsd read /dev/mmcblk0 | grep -E 'Life Time|EOL'",
        "grep mmcblk0p14 /proc/diskstats",
        "cat /proc/uptime"
    ],

    "command_parsers": [
        {
            "command": "cat /sys/block/mmcblk0/device/name",
            "extract": {
                "devName": "^\\s*(.+?)\\s*$"
            }
        },
        {
            "command": "/sbin/mmc extcsd read /dev/mmcblk0 | grep -E 'Life Time|EOL'",
            "extract": {
                "EST_TYP_A": "EST_TYP_A\\]:\\s*(0x[0-9a-fA-F]+)",
                "EST_TYP_B": "EST_TYP_B\\]:\\s*(0x[0-9a-fA-F]+)",
                "EOL_INFO": "EOL_INFO\\]:\\s*(0x[0-9a-fA-F]+)"
            }
        },
        {
            "command": "grep mmcblk0p14 /proc/diskstats",
            "extract_by_split": {
                "match_line": "mmcblk0p14",
                "fields": {
                    "ds_reads": 3,
                    "ds_reads_merged": 4,
                    "ds_sectors_read": 5,
                    "ds_read_time_ms": 6,
                    "ds_writes": 7,
                    "ds_writes_merged": 8,
                    "ds_sectors_written": 9,
                    "ds_write_time_ms": 10,
                    "ds_io_in_progress": 11,
                    "ds_io_time_ms": 12,
                    "ds_weighted_io_time_ms": 13
                }
            }
        },
        {
            "command": "cat /proc/uptime",
            "extract": {
                "sys_uptime": "(\\d+\\.\\d+)\\s+\\d+\\.\\d+"
            }
        }
    ],

    "log_level": "INFO",

    "timeout_page_load": 30000,
    "timeout_terminal_ready": 30000,
    "timeout_prompt_wait": 30000,
    "timeout_command_wait": 30000,
    "type_delay": 50,
    "devtools": false
}
